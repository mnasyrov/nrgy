{
  "private": true,
  "name": "nrgy-root",
  "version": "0.0.1",
  "description": "The library for reactive programming with MVC/MVVM patterns",
  "license": "MIT",
  "author": "Mikhail Nasyrov (https://github.com/mnasyrov)",
  "homepage": "https://github.com/mnasyrov/nrgy",
  "bugs": "https://github.com/mnasyrov/nrgy/issues",
  "repository": "github:mnasyrov/nrgy",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "test -d .git && husky || true",
    "husky-precommit": "biome check --staged --write --no-errors-on-unmatched",
    "deps-check": "npx -y npm-check-updates --format 'group,repo,time'",
    "deps-upgrade": "npm run deps-check -- --upgrade",
    "clean": "rm -rf build coverage dist packages/{core,ditox,ditox-react,react,rx-effects,rxjs}/dist",
    "format": "biome check --write",
    "check": "npm run check-sources && npm run check-types",
    "check-sources": "biome check",
    "check-types": "tsc --noEmit --jsx react-jsx",
    "build": "tsdown",
    "test": "vitest --run",
    "test-watch": "vitest --watch",
    "test-coverage": "vitest --run --coverage",
    "pack": "npm run build && mkdir -p dist && cd dist && npm pack --workspaces",
    "preversion": "npm run check && npm run build && npm run test && git add --all",
    "publish": "npm run build && cd dist && npm publish",
    "benchmark": "npm run -w nrgy-benchmarks start"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@biomejs/biome": "2.3.15",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "4.0.18",
    "ditox": "3.1.0",
    "ditox-react": "3.1.0",
    "happy-dom": "20.6.1",
    "husky": "9.1.7",
    "publint": "0.3.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-test-renderer": "19.2.4",
    "rxjs": "7.8.2",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "attributions": [
    {
      "energy.svg": [
        "UXWing, https://uxwing.com/license",
        "https://uxwing.com/wp-content/themes/uxwing/download/computers-mobile-hardware/energy-icon.svg"
      ]
    }
  ],
  "keywords": [
    "state",
    "effect",
    "management",
    "reactive",
    "rxjs",
    "react",
    "typescript",
    "atom",
    "signals",
    "MVC",
    "MVVM"
  ]
}
